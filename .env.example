# ═══════════════════════════════════════════════
# FounderOS — Environment Configuration
# ═══════════════════════════════════════════════

# Lyzr Agent Orchestration (required)
# Get your key at https://studio.lyzr.ai
LYZR_API_KEY=your_lyzr_api_key_here
LYZR_MODEL=gpt-4o-mini

# Qdrant Vector Memory (required)
# For local Docker: http://localhost:6333
# For Qdrant Cloud: https://your-cluster.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# OpenAI Embeddings (required)
# Used for text-embedding-3-small (1536 dims)
OPENAI_API_KEY=your_openai_api_key_here

# Omi Voice Integration
# Webhook secret for payload verification (optional)
OMI_WEBHOOK_SECRET=

# EnkryptAI Guardrails (optional differentiator)
# Get your key at https://www.enkryptai.com
ENKRYPT_API_KEY=

# Application Config
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=info
